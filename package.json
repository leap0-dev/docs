{
  "name": "leap0-docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "generate:python-sdk-reference": "python3 ./scripts/generate-python-sdk-reference.py --output-root \"./content/docs/(python-sdk)/reference/python-sdk\"",
    "generate:javascript-sdk-reference": "node ./scripts/generate-javascript-sdk-reference.mjs",
    "predev": "pnpm generate:python-sdk-reference && pnpm generate:javascript-sdk-reference",
    "prebuild": "pnpm generate:python-sdk-reference && pnpm generate:javascript-sdk-reference",
    "prestart": "pnpm generate:python-sdk-reference && pnpm generate:javascript-sdk-reference",
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-router": "1.168.22",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-start": "1.167.41",
    "beautiful-mermaid": "^1.1.3",
    "fumadocs-core": "16.7.16",
    "fumadocs-mdx": "14.2.14",
    "fumadocs-openapi": "10.7.0",
    "fumadocs-ui": "16.7.16",
    "lucide-react": "^1.8.0",
    "posthog-js": "^1.369.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-directive": "^4.0.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
